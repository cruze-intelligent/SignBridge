# Copy this file to .env and fill in the values before deploying.

# Server port (default: 8000; hosting platforms set this automatically)
PORT=8000

# Set to "production" to disable hot-reload
ENV=development

# Comma-separated list of allowed CORS origins.
# Use "*" for open access during development.
# Example for GitHub Pages: ALLOWED_ORIGINS=https://cruze-intelligent.github.io
ALLOWED_ORIGINS=*
