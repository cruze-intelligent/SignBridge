# byte-compiled / optimised cache
__pycache__/
*.py[cod]
*$py.class

# virtual environment
.venv/
venv/
env/

# storage — the .npy files are generated data, not source code
storage/sequences/

# IDE
.idea/
.vscode/
*.swp

# ML — large dataset splits (re-generatable from sequences)
# X_train / X_test / y_train / y_test are excluded; label_map files ARE tracked.
ml/dataset/X_*.npy
ml/dataset/y_*.npy

# ML — training artefacts not needed at runtime
models/logs/
models/training_history.json

# model weights (*.h5, *.keras) are intentionally tracked so Railway
# can load them at startup — do NOT add them back here.
